{
  "manifest_version": 3,
  "name": "Marvis Console Bridge",
  "version": "0.1.0",
  "description": "Passively reads Mist session credentials and makes them available to the Marvis Console app.",
  "permissions": ["cookies"],
  "host_permissions": [
    "*://*.mist.com/*",
    "*://*.mistsys.net/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "http://127.0.0.1/*"
    ]
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
