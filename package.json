{
  "name": "junos-console",
  "version": "0.7.0",
  "description": "Browser-based serial terminal for Juniper Mist switches running Junos",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,green \"npm run dev:server\" \"wait-on tcp:127.0.0.1:3333 && npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "node server/index.mjs",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "start:server": "node server/index.mjs"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/w3c-web-serial": "^1.0.7",
    "@types/ws": "^8.5.14",
    "concurrently": "^9.1.0",
    "wait-on": "^8.0.1",
    "typescript": "^5.7.0",
    "vite": "^6.4.1"
  }
}
